@page "/speedtypes"
@model SpeedTypesModel
@{
    ViewData["Title"] = "SpeedTypes";
}

<div class="container">

    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">
    <!-- SpeedType List Card -->
    <div class="card mb-4 shadow-sm" style="border-radius: 10px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 10px;">
                <h3 class="page-title">SpeedTypes</h3>
                <div class="d-flex gap-2">
                    <form method="post" asp-page-handler="ExportToExcelSpeedTypes" id="speedTypesExportForm">
                        <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                        <input type="hidden" name="SpeedTypeMinBudget" value="@Model.SpeedTypeMinBudget" />
                        <input type="hidden" name="SpeedTypeMaxBudget" value="@Model.SpeedTypeMaxBudget" />
                        <input type="hidden" name="ExportAll" value="false" id="speedTypesExportAllFlag" />
                        <div class="btn-group">
                            <button type="submit" class="btn btn-outline-success" id="speedTypesExportBtn"
                                    onclick="triggerExport('speedTypesExportForm', 'speedTypesExportBtn', 'speedTypesExportAllFlag', false)">
                                <i class="fas fa-file-excel me-1"></i> Export
                            </button>
                            <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="visually-hidden">Toggle Dropdown</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="#"
                                       onclick="triggerExport('speedTypesExportForm', 'speedTypesExportBtn', 'speedTypesExportAllFlag', true); return false;">
                                        <i class="fas fa-table me-2"></i>Export All
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </form>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSpeedTypeModal">
                        Add New +
                    </button>
                </div>
            </div>
            <!-- Search Bar -->
            <form method="get">
                <div class="input-group mb-3">
                    <input type="text" name="SpeedTypeSearchTerm" class="form-control" placeholder="Search..." value="@Model.SpeedTypeSearchTerm" />
                    <button type="submit" class="btn btn-outline-secondary">Search</button>
                </div>
            </form>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover text-center">
                    <thead>
                        <tr>
                            <th>
                                #
                            </th>
                            <th>
                                Code
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="SpeedType" />
                                    <input type="hidden" name="column" value="Code" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("Code")" />
                                    <input type="hidden" name="speedTypePageNumber" value="@Model.SpeedTypeCurrentPage" />
                                    <input type="hidden" name="speedTypesPerPage" value="@Model.SpeedTypeResultsPerPage" />
                                    <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("Code")"></i>
                                    </button>
                                </form>
                            </th>
                            <th>
                                Budget
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="SpeedType" />
                                    <input type="hidden" name="column" value="Budget" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("Budget")" />
                                    <input type="hidden" name="speedTypePageNumber" value="@Model.SpeedTypeCurrentPage" />
                                    <input type="hidden" name="speedTypesPerPage" value="@Model.SpeedTypeResultsPerPage" />
                                    <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("Budget")"></i>
                                    </button>
                                </form>

                                <div class="dropdown d-inline">
                                    <button class="btn btn-sm btn-light dropdown-toggle" type="button" id="speedTypeBudgetFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fas fa-filter"></i>
                                    </button>

                                    <div class="dropdown-menu p-3 shadow-lg" style="min-width: 250px;">
                                        <form method="get" id="speedTypeBudgetFilterForm">
                                            <div class="mb-2">
                                                <label class="form-label">Min Budget</label>
                                                <input type="number" step="0.01" name="SpeedTypeMinBudget" id="speedTypeMinBudgetInput" class="form-control form-control-sm"
                                                       value="@(Model.SpeedTypeMinBudget?.ToString("0.##") ?? "")" />
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label">Max Budget</label>
                                                <input type="number" step="0.01" name="SpeedTypeMaxBudget" id="speedTypeMaxBudgetInput" class="form-control form-control-sm"
                                                       value="@(Model.SpeedTypeMaxBudget?.ToString("0.##") ?? "")" />
                                            </div>

                                            <div class="d-flex justify-content-start gap-2 mt-3">
                                                <button type="submit" class="btn btn-sm btn-primary" id="speedTypeFilterApplyButton" disabled>Apply</button>
                                                <button type="button" class="btn btn-sm btn-secondary" onclick="resetSpeedTypeBudgetFields()">Reset</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </th>

                            <th>
                                Fund Code
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="SpeedType" />
                                    <input type="hidden" name="column" value="FundCode" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("FundCode")" />
                                    <input type="hidden" name="speedTypePageNumber" value="@Model.SpeedTypeCurrentPage" />
                                    <input type="hidden" name="speedTypesPerPage" value="@Model.SpeedTypeResultsPerPage" />
                                    <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("FundCode")"></i>
                                    </button>
                                </form>
                            </th>

                            <th>
                                Program Code
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="SpeedType" />
                                    <input type="hidden" name="column" value="ProgramCode" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("ProgramCode")" />
                                    <input type="hidden" name="speedTypePageNumber" value="@Model.SpeedTypeCurrentPage" />
                                    <input type="hidden" name="speedTypesPerPage" value="@Model.SpeedTypeResultsPerPage" />
                                    <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("ProgramCode")"></i>
                                    </button>
                                </form>
                            </th>

                            <th>
                                Class Code
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="SpeedType" />
                                    <input type="hidden" name="column" value="ClassCode" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("ClassCode")" />
                                    <input type="hidden" name="speedTypePageNumber" value="@Model.SpeedTypeCurrentPage" />
                                    <input type="hidden" name="speedTypesPerPage" value="@Model.SpeedTypeResultsPerPage" />
                                    <input type="hidden" name="SpeedTypeSearchTerm" value="@Model.SpeedTypeSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("ClassCode")"></i>
                                    </button>
                                </form>
                            </th>

                            <th colspan="2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.SpeedTypes != null)
                        {
                            int index = 1;
                            @foreach (var speedType in Model.SpeedTypes)
                            {
                                if (Model.EditingSpeedTypeID == speedType.SpeedTypeId)
                                {
                                    <tr>
                                        <form method="post" asp-route-id="@speedType.SpeedTypeId">
                                        <td>@index</td>
                                        <td><input asp-for="NewSpeedType.Code" value="@speedType.Code" class="form-control" /></td>
                                        <td><input asp-for="NewSpeedType.Budget" value="@speedType.Budget" class="form-control" /></td>
                                        <td><input asp-for="NewSpeedType.FundCode" value="@speedType.FundCode" class="form-control" /></td>
                                        <td><input asp-for="NewSpeedType.ProgramCode" value="@speedType.ProgramCode" class="form-control" /></td>
                                        <td><input asp-for="NewSpeedType.ClassCode" value="@speedType.ClassCode" class="form-control" /></td>
                                        <td>
                                            <div class="d-flex justify-content-evenly">
                                                <button type="submit" asp-page-handler="SaveSpeedType" asp-route-id="@speedType.SpeedTypeId" class="btn btn-success" onclick="return confirm('Save changes to this speed type?')">Save</button>
                                                <button type="submit" asp-page-handler="CancelEditSpeedType" asp-route-id="@speedType.SpeedTypeId" class="btn btn-secondary" onclick="return confirm('Cancel editing? Unsaved changes will be lost.')">Cancel</button>
                                            </div>
                                        </td>
                                        </form>
                                    </tr>

                                }
                                else
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td>@speedType.Code</td>
                                        <td>$@speedType.Budget.ToString("N2")</td>
                                        <td>@speedType.FundCode</td>
                                        <td>@speedType.ProgramCode</td>
                                        <td>@speedType.ClassCode</td>
                                        <td>
                                            <div class="d-flex justify-content-evenly gap-3">
                                                <form method="post" asp-page-handler="EditSpeedType" asp-route-id="@speedType.SpeedTypeId">
                                                    <button type="submit" class="btn btn-outline-secondary">Edit</button>
                                                </form>
                                                <form method="post" asp-page-handler="DeleteSpeedType" asp-route-id="@speedType.SpeedTypeId"
                                                      onsubmit="return confirm('Delete speed type \'@speedType.Code\'? This cannot be undone.')">
                                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                index++;
                            }
                        }

                        else
                        {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="py-5">
                                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                    <p class="text-muted mb-0">No records found</p>
                                    <small class="text-muted">Click the Add New + button to create a new speed type</small>
                                </div>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.SpeedTypes != null)
            {
                var speedTypePagination = new budget_management_system_aspdotnetcore.ViewModels.PaginationViewModel
                {
                    CurrentPage = Model.SpeedTypeCurrentPage,
                    TotalPages = Model.SpeedTypeTotalPages,
                    TotalRecords = Model.TotalSpeedTypes,
                    ResultsPerPage = Model.SpeedTypeResultsPerPage,
                    PageSizes = Model.PageSizes,
                    AriaLabel = "Speed type page navigation",
                    PrevUrl = Url.Page(null, new { speedTypePageNumber = Model.SpeedTypeCurrentPage - 1, speedTypesPerPage = Model.SpeedTypeResultsPerPage, SpeedTypeSearchTerm = Model.SpeedTypeSearchTerm, SpeedTypeMinBudget = Model.SpeedTypeMinBudget, SpeedTypeMaxBudget = Model.SpeedTypeMaxBudget }),
                    NextUrl = Url.Page(null, new { speedTypePageNumber = Model.SpeedTypeCurrentPage + 1, speedTypesPerPage = Model.SpeedTypeResultsPerPage, SpeedTypeSearchTerm = Model.SpeedTypeSearchTerm, SpeedTypeMinBudget = Model.SpeedTypeMinBudget, SpeedTypeMaxBudget = Model.SpeedTypeMaxBudget }),
                    SizeChangeUrlTemplate = Url.Page(null, new { speedTypePageNumber = 1, speedTypesPerPage = "__SIZE__", SpeedTypeSearchTerm = Model.SpeedTypeSearchTerm, SpeedTypeMinBudget = Model.SpeedTypeMinBudget, SpeedTypeMaxBudget = Model.SpeedTypeMaxBudget })
                };
                <partial name="_Pagination" model="speedTypePagination" />
            }

        </div>
    </div>

        </div>
    </div>

    <!-- Add SpeedType Modal -->
    <div class="modal fade" id="addSpeedTypeModal" tabindex="-1" aria-labelledby="addSpeedTypeModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addSpeedTypeModalLabel">Add New SpeedType</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-page-handler="AddSpeedType">
                        <div class="mb-3">
                            <label asp-for="NewSpeedType.Code" class="form-label">SpeedType Code:</label>
                            <input asp-for="NewSpeedType.Code" class="form-control" />
                            <span asp-validation-for="NewSpeedType.Code" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewSpeedType.Budget" class="form-label">Budget (in US$):</label>
                            <input asp-for="NewSpeedType.Budget" class="form-control" />
                            <span asp-validation-for="NewSpeedType.Budget" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewSpeedType.FundCode" class="form-label">Fund Code: </label>
                            <input asp-for="NewSpeedType.FundCode" class="form-control" />
                            <span asp-validation-for="NewSpeedType.FundCode" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewSpeedType.ProgramCode" class="form-label">Program Code: </label>
                            <input asp-for="NewSpeedType.ProgramCode" class="form-control" />
                            <span asp-validation-for="NewSpeedType.ProgramCode" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewSpeedType.ClassCode" class="form-label">Class Code: </label>
                            <input asp-for="NewSpeedType.ClassCode" class="form-control" />
                            <span asp-validation-for="NewSpeedType.ClassCode" class="text-danger"></span>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Add</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>


<script>
    const speedTypeMinInput = document.getElementById('speedTypeMinBudgetInput');
    const speedTypeMaxInput = document.getElementById('speedTypeMaxBudgetInput');
    const speedTypeApplyButton = document.getElementById('speedTypeFilterApplyButton');
    const speedTypeForm = document.getElementById("speedTypeBudgetFilterForm");

    function updateApplyButtonState() {
        speedTypeApplyButton.disabled = !speedTypeMinInput.value && !speedTypeMaxInput.value;
    }

    function resetSpeedTypeBudgetFields() {
        speedTypeMinInput.value = '';
        speedTypeMaxInput.value = '';
        updateApplyButtonState();
        speedTypeForm.submit();
    }

    speedTypeMinInput.addEventListener('input', updateApplyButtonState);
    speedTypeMaxInput.addEventListener('input', updateApplyButtonState);

    // Run on load
    updateApplyButtonState();

    document.addEventListener('DOMContentLoaded', function () {
    const speedTypeDropdownMenu = document.querySelector('#speedTypeBudgetFilterDropdown + .dropdown-menu');

        if (speedTypeDropdownMenu) {
            speedTypeDropdownMenu.addEventListener('click', function (e) {
                    e.stopPropagation(); // Prevents the dropdown from closing on click inside
                });
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showExportToast() {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-success alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-check-circle me-2"></i> Your file is downloading. <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const container = document.querySelector('.container-fluid');
            const main = container.querySelector('main[role="main"]');
            container.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function triggerExport(formId, btnId, flagId, exportAll) {
            const btn = document.getElementById(btnId);
            const flag = document.getElementById(flagId);
            flag.value = exportAll ? 'true' : 'false';
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Exporting...';
            setTimeout(function () {
                btn.innerHTML = originalHtml;
                flag.value = 'false';
                showExportToast();
            }, 2000);
            if (exportAll) {
                document.getElementById(formId).submit();
            }
        }
    </script>
}

@page "/baedit"
@model BAEditModel
@{
    ViewData["Title"] = "Modify Budget Amendments";
}
@using budget_management_system_aspdotnetcore.Entities

<div class="container-fluid">

    @{
        var userRole = Model.userRole;
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Budget Amendment History Card -->
    <div class="card mb-4 card-macos" style="border-radius: 10px; max-width: 960px; margin-left: auto; margin-right: auto;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 10px;">
                <h3 class="page-title">Budget Amendments</h3>

                @if (!String.Equals(userRole, "5"))
                {
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAmendmentMainModal">
                        Create New +
                    </button>
                }
            </div>

            @{
                var fyFilterModel = new FinancialYearFilterViewModel
                {
                    FinancialYearOptions = Model.FinancialYearOptions,
                    SelectedFinancialYear = Model.SelectedFinancialYear,
                    CustomStartDate = Model.CustomStartDate,
                    CustomEndDate = Model.CustomEndDate
                };
                var tabBarModel = new BAMainTabBarViewModel
                {
                    SelectedBAMainStatusTab = Model.SelectedBAMainStatusTab,
                    SelectedFinancialYear = Model.SelectedFinancialYear,
                    CustomStartDate = Model.CustomStartDate,
                    CustomEndDate = Model.CustomEndDate,
                    TabCounts = new Dictionary<string, int>
                    {
                        [""] = Model.BudgetAmendmentsMainAll.Count,
                        ["Pending"] = Model.BudgetAmendmentsMainAll.Count(bam =>
                            Model.BudgetAmendmentsAll.Any(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID && ba.Status == AmendmentStatus.Pending)),
                        ["Approved"] = Model.BudgetAmendmentsMainAll.Count(bam => {
                            var rel = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID).ToList();
                            return rel.Any() && rel.All(ba => ba.Status == AmendmentStatus.Approved);
                        }),
                        ["Rejected"] = Model.BudgetAmendmentsMainAll.Count(bam => {
                            var rel = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID).ToList();
                            return rel.Any() && rel.All(ba => ba.Status == AmendmentStatus.Rejected);
                        })
                    }
                };
            }
            <partial name="_FinancialYearFilter" model="fyFilterModel" />
            <div class="mt-3">
                <partial name="_BAMainTabBar" model="tabBarModel" />
            </div>

            @if (!Model.BudgetAmendmentsMain.Any())
            {
                <div class="d-flex justify-content-center align-items-center">
                    <div class="card" style="background-color: #e9ecef; border: 1px solid #dee2e6; padding: 3rem; width: 100%;">
                        <div class="card-body text-center">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">No records found</p>
                            <small class="text-muted">Click the Create New + button to create a new budget amendment</small>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var amendmentmain in Model.BudgetAmendmentsMain)
                {
                    var extCount = Model.DeptExtensionCounts.GetValueOrDefault(amendmentmain.BudgetAmendmentMainID, 0);
                    var baRelated = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID).ToList();
                    var baMainStatus = baRelated.Any(ba => ba.Status == AmendmentStatus.Pending) ? "Pending"
                        : (baRelated.Any() && baRelated.All(ba => ba.Status == AmendmentStatus.Approved)) ? "Approved"
                        : (baRelated.Any() && baRelated.All(ba => ba.Status == AmendmentStatus.Rejected)) ? "Rejected"
                        : "None";
                    <div class="d-flex justify-content-between align-items-center px-4 py-4 mb-2" style="border: 1px solid #dee2e6; border-radius: 8px; background-color: #f1f3f5;">
                        <partial name="_BAMainHeader" model="new BAMainHeaderViewModel { Record = amendmentmain, Status = baMainStatus }" />
                        @if (extCount > 0)
                        {
                            <span class="badge bg-secondary ms-3">@extCount dept override@(extCount == 1 ? "" : "s")</span>
                        }
                        @if (!String.Equals(userRole, "5"))
                        {
                            <button class="btn btn-outline-secondary me-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editBudgetAmendmentModal"
                                    data-ba-id="@amendmentmain.BudgetAmendmentMainID"
                                    data-ba-name="@amendmentmain.Name"
                                    data-ba-start="@amendmentmain.StartDate.ToString("yyyy-MM-ddTHH:mm")"
                                    data-ba-end="@amendmentmain.EndDate.ToString("yyyy-MM-ddTHH:mm")"
                                    data-ba-extend="@amendmentmain.ExtendedDeadline.ToString("yyyy-MM-ddTHH:mm")">
                                Edit
                            </button>
                        }
                    </div>
                }

                <partial name="_Pagination" model="Model.GetBAMainPagination()" />
            }

        </div>
    </div>

    <!-- Add Budget Amendment Main Modal -->
    <div class="modal fade" id="addAmendmentMainModal" tabindex="-1" aria-labelledby="addAmendmentMainModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addAmendmentMainModalLabel">Create New Budget Amendment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-page-handler="AddAmendmentMain" id="addBudgetAmendmentForm">
                        <div class="mb-3">
                            <label asp-for="NewBudgetAmendmentMain.Name" class="form-label">Budget Amendment Name: <span class="text-danger ms-1">*</span></label>
                            <input asp-for="NewBudgetAmendmentMain.Name" class="form-control" placeholder="e.g. BA#4" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewBudgetAmendmentMain.StartDate" class="form-label">Start Date: <span class="text-danger ms-1">*</span></label>
                            <input asp-for="NewBudgetAmendmentMain.StartDate" type="datetime-local" class="form-control" id="startDate" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewBudgetAmendmentMain.EndDate" class="form-label">End Date: <span class="text-danger ms-1">*</span></label>
                            <input asp-for="NewBudgetAmendmentMain.EndDate" type="datetime-local" class="form-control" id="endDate" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                            <div class="invalid-feedback" id="dateError">End date must be after start date.</div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Create</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Budget Amendment Main Modal -->
    <div class="modal fade" id="editBudgetAmendmentModal" tabindex="-1" aria-labelledby="editBudgetAmendmentLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <form method="post" asp-page-handler="ExtendDeadline">
                    <input type="hidden" id="editBAId" name="BudgetAmendmentMainID" />

                    <div class="modal-header">
                        <h5 class="modal-title" id="editBudgetAmendmentLabel">Edit Budget Amendment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">Budget Amendment Name: </label>
                            <input id="editBAName" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Start Date: </label>
                            <input id="editBAStart" type="datetime-local" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">End Date: </label>
                            <input id="editBAEnd" type="datetime-local" class="form-control" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Extend Deadline To:</label>
                            <input id="editBAExtendDeadline" name="ExtendDeadlineTo"
                                   type="datetime-local" class="form-control" required />
                            <div class="invalid-feedback">
                                New deadline must be after the current end date.
                            </div>
                        </div>

                        <div class="mb-3 d-flex flex-column">
                            <label class="form-label">Departments to Apply To:</label>
                            <select id="editBADeptSelect" name="SelectedDepartments" class="selectpicker w-100" multiple data-live-search="true">
                                <option value="ALL" selected>All Departments</option>
                                @foreach (var dept in Model.Departments)
                                {
                                    <option value="@dept.DepartmentID" data-tokens="@dept.DepartmentName">
                                        @dept.DepartmentName
                                    </option>
                                }
                            </select>
                            <small class="text-muted">Extending the deadline for All Departments will override any extensions set for specific departments.</small>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            toggleDateRange(document.getElementById("financialYear").value);

            document.getElementById('addBudgetAmendmentForm').addEventListener('submit', function (e) {
                const startDate = new Date(document.getElementById('startDate').value);
                const endDate = new Date(document.getElementById('endDate').value);
                const dateError = document.getElementById('dateError');
                const endDateInput = document.getElementById('endDate');

                if (startDate >= endDate) {
                    e.preventDefault();
                    endDateInput.classList.add('is-invalid');
                    dateError.style.display = 'block';
                } else {
                    endDateInput.classList.remove('is-invalid');
                    dateError.style.display = 'none';
                }
            });

            document.getElementById('endDate').addEventListener('change', function () {
                this.classList.remove('is-invalid');
                document.getElementById('dateError').style.display = 'none';
            });
            document.getElementById('startDate').addEventListener('change', function () {
                document.getElementById('endDate').classList.remove('is-invalid');
                document.getElementById('dateError').style.display = 'none';
            });

            // Edit modal — all listeners attached once, not per modal open
            const editModal = document.getElementById('editBudgetAmendmentModal');
            const extendInput = document.getElementById('editBAExtendDeadline');
            const endInput = document.getElementById('editBAEnd');
            const saveButton = document.querySelector("#editBudgetAmendmentModal button[type='submit']");

            function validateExtend() {
                if (!extendInput.value || !endInput.value) {
                    saveButton.disabled = true;
                    return;
                }
                const extendVal = new Date(extendInput.value);
                const endVal = new Date(endInput.value);
                if (extendVal <= endVal) {
                    saveButton.disabled = true;
                    extendInput.classList.add('is-invalid');
                } else {
                    saveButton.disabled = false;
                    extendInput.classList.remove('is-invalid');
                }
            }

            extendInput.addEventListener('change', validateExtend);
            editModal.addEventListener('shown.bs.modal', validateExtend);

            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                document.getElementById('editBAId').value = button.getAttribute('data-ba-id');
                document.getElementById('editBAName').value = button.getAttribute('data-ba-name');
                document.getElementById('editBAStart').value = button.getAttribute('data-ba-start');
                endInput.value = button.getAttribute('data-ba-end');
                extendInput.value = button.getAttribute('data-ba-extend');
                $('#editBADeptSelect').selectpicker('refresh');
            });

            $('#editBADeptSelect').on('changed.bs.select', function (e, clickedIndex, isSelected, previousValue) {
                var current = $(this).val() || [];
                var previous = previousValue || [];
                var allNowSelected = current.includes('ALL');
                var hasOtherSelections = current.some(function (v) { return v !== 'ALL'; });

                if (allNowSelected && hasOtherSelections) {
                    if (previous.includes('ALL')) {
                        // ALL was already selected; user added a specific dept — remove ALL
                        $(this).find('option[value="ALL"]').prop('selected', false);
                    } else {
                        // User just selected ALL — clear specific selections
                        $(this).val(['ALL']);
                    }
                    $(this).selectpicker('refresh');
                }
            });

        });
    </script>
}

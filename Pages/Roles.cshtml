@page "/roles"
@model RolesModel
@{
    ViewData["Title"] = "Roles";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
    <!-- Roles List Card -->
    <div class="card mb-4 card-macos" style="border-radius: 10px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="page-title">Roles</h3>
            </div>

            <!-- Search Bar -->
            <div class="d-flex gap-2 mb-3 align-items-center">
                <form method="get" class="flex-grow-1">
                    <div class="input-group search-group">
                        <input type="text" name="RoleSearchTerm" class="form-control" placeholder="Search roles..." value="@Model.RoleSearchTerm" />
                        <button type="submit" class="btn btn-outline-secondary border-start-0" style="color: #6c757d;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
                @if (!string.IsNullOrEmpty(Model.RoleSearchTerm))
                {
                    <a href="/roles" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-1"></i> Clear filters
                    </a>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover text-center">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Role Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Roles != null && Model.Roles.Any())
                        {
                            int index = (Model.RoleCurrentPage - 1) * Model.RoleResultsPerPage + 1;
                            @foreach (var role in Model.Roles)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@role.RoleName</td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center py-5">
                                    <div class="py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted mb-0">No records found</p>
                                        <small class="text-muted">Contact your administrator to add a new role</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Roles != null && Model.Roles.Any())
            {
                var rolePagination = new budget_management_system_aspdotnetcore.ViewModels.PaginationViewModel
                {
                    CurrentPage = Model.RoleCurrentPage,
                    TotalPages = Model.RoleTotalPages,
                    TotalRecords = Model.TotalRoles,
                    ResultsPerPage = Model.RoleResultsPerPage,
                    PageSizes = Model.PageSizes,
                    AriaLabel = "Role page navigation",
                    PrevUrl = Url.Page(null, new { rolePageNumber = Model.RoleCurrentPage - 1, roleResultsPerPage = Model.RoleResultsPerPage, roleSearchTerm = Model.RoleSearchTerm }),
                    NextUrl = Url.Page(null, new { rolePageNumber = Model.RoleCurrentPage + 1, roleResultsPerPage = Model.RoleResultsPerPage, roleSearchTerm = Model.RoleSearchTerm }),
                    SizeChangeUrlTemplate = Url.Page(null, new { rolePageNumber = 1, roleResultsPerPage = "__SIZE__", roleSearchTerm = Model.RoleSearchTerm })
                };
                <partial name="_Pagination" model="rolePagination" />
            }
        </div>
    </div>
        </div>
    </div>
</div>

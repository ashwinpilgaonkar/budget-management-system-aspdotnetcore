@using budget_management_system_aspdotnetcore.ViewModels
@model PaginationViewModel
@{
    int start = Model.TotalRecords == 0 ? 0 : (Model.CurrentPage - 1) * Model.ResultsPerPage + 1;
    int end = Math.Min(Model.CurrentPage * Model.ResultsPerPage, Model.TotalRecords);
}
<nav class="d-flex justify-content-between align-items-center my-3" aria-label="@Model.AriaLabel">
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted small">Show:</span>
        <ul class="pagination pagination-sm mb-0 pagination-show" aria-label="Results per page">
            @foreach (var size in Model.PageSizes)
            {
                var sizeUrl = Model.SizeChangeUrlTemplate.Replace("__SIZE__", size.ToString());
                var isDisabled = Model.TotalRecords < size && Model.ResultsPerPage != size;
                <li class="page-item @(Model.ResultsPerPage == size ? "active" : "") @(isDisabled ? "disabled" : "")">
                    <a href="@(isDisabled ? "#" : sizeUrl)"
                       class="page-link"
                       @(isDisabled ? "aria-disabled=\"true\" tabindex=\"-1\"" : "")>@size</a>
                </li>
            }
        </ul>
    </div>
    <span class="text-muted small">Showing @start&ndash;@end of @Model.TotalRecords</span>
    <ul class="pagination mb-0">
        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
            <a class="page-link" href="@Model.PrevUrl" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
            </a>
        </li>
        <li class="page-item active">
            <span class="page-link">@Model.CurrentPage</span>
        </li>
        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" href="@Model.NextUrl" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
            </a>
        </li>
    </ul>
</nav>

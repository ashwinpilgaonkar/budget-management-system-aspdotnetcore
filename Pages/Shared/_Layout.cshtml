@using budget_management_system_aspdotnetcore.Services
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject IAuthenticationService AuthService
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Budget Management</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/css/bootstrap-select.min.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </head>
    <body>
        <header class="sticky-top">
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-light mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">CAS Budget Management</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        @if (HttpContextAccessor.HttpContext.Session.GetString("Email") != null)
                        {
                            var userRole = AuthService.GetUserRole(HttpContextAccessor.HttpContext);
                            var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

                            <ul class="navbar-nav flex-grow-1 justify-content-center">
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentPage.EndsWith("Dashboard", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Dashboard">📊 Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentPage.EndsWith("Index", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Index">🗂️ View Amendments</a>
                                </li>
                                @if (!String.Equals(userRole, "5"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark @(currentPage.EndsWith("BAEdit", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/BAEdit">✏️ Edit Amendments</a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentPage.EndsWith("Activitylog", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Activitylog">📋 Audit Log</a>
                                </li>

                                @if (!String.Equals(userRole, "5"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark @(currentPage.EndsWith("Users", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Users">👥 Users</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark @(currentPage.EndsWith("Departments", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Departments">🏢 Departments</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark @(currentPage.EndsWith("Speedtypes", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Speedtypes">🏷️ Speed Types</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark @(currentPage.EndsWith("Roles", StringComparison.OrdinalIgnoreCase) ? "active fw-semibold" : "")" asp-area="" asp-page="/Roles">🔐 Roles</a>
                                    </li>
                                }
                            </ul>
                            <div class="d-flex align-items-center ms-3">
                                <div class="d-flex align-items-center gap-2 me-4">
                                    <span class="navbar-text text-muted">
                                        @HttpContextAccessor.HttpContext.Session.GetString("FirstName")
                                        @HttpContextAccessor.HttpContext.Session.GetString("LastName")
                                    </span>
                                    <span class="navbar-vr"></span>
                                    <span class="badge navbar-role-badge">@HttpContextAccessor.HttpContext.Session.GetString("RoleName")</span>
                                </div>
                                <a class="btn btn-sm btn-logout" asp-area="" asp-page="/Logout" onclick="return confirm('Are you sure you want to log out?')">Log Out</a>
                            </div>
                        }
                    </div>
                </div>
            </nav>
        </header>

        <div class="container-fluid">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert" style="width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container text-center">
                &copy; 2026 - CAS Budget Management
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.14.0-beta3/dist/js/bootstrap-select.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)

        <script>
            $(document).ready(function () {
                $('.selectpicker').selectpicker();
                setTimeout(function () {
                    $('.alert').alert('close');
                }, 8000);

                function updateHeaderShadow() {
                    $('header.sticky-top').toggleClass('scrolled', window.scrollY > 0);
                }
                $(window).on('scroll', updateHeaderShadow);
                updateHeaderShadow();
            });
        </script>
    </body>
</html>

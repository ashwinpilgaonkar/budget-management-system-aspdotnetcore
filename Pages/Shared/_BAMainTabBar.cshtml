@model budget_management_system_aspdotnetcore.ViewModels.BAMainTabBarViewModel
@{
    var tabs = new[] {
        (Label: "Pending",  Value: "Pending"),
        (Label: "Approved", Value: "Approved"),
        (Label: "Rejected", Value: "Rejected"),
        (Label: "All",      Value: "All")
    };
    var overdueEligible = new HashSet<string?> { "Pending", "Rejected", "All" };
    bool isEligible = overdueEligible.Contains(Model.SelectedBAMainStatusTab ?? "Pending");
    var fyParams = $"SelectedFinancialYear={Model.SelectedFinancialYear}&CustomStartDate={Model.CustomStartDate?.ToString("yyyy-MM-dd")}&CustomEndDate={Model.CustomEndDate?.ToString("yyyy-MM-dd")}";
    var collapsedParam = Model.BAMainCollapsed ? "&BAMainCollapsed=true" : "";
    var contextParams = "";
    if (Model.SelectedDepartmentID != 0)
        contextParams += $"&SelectedDepartmentID={Model.SelectedDepartmentID}";
    if (Model.SelectedBudgetAmendmentMainID.HasValue)
        contextParams += $"&SelectedBudgetAmendmentMainID={Model.SelectedBudgetAmendmentMainID}";
    if (!string.IsNullOrEmpty(Model.SelectedStatusTab))
        contextParams += $"&SelectedStatusTab={Model.SelectedStatusTab}";
    if (Model.EditingBudgetAmendmentID.HasValue && Model.EditingBudgetAmendmentID > 0)
        contextParams += $"&EditingBudgetAmendmentID={Model.EditingBudgetAmendmentID}";
    if (Model.SourceSpeedtype != 0)
        contextParams += $"&SourceSpeedtype={Model.SourceSpeedtype}";
    if (Model.DestinationSpeedtype != 0)
        contextParams += $"&DestinationSpeedtype={Model.DestinationSpeedtype}";
    var toggleHref = Model.ShowOverdueOnly
        ? $"?SelectedBAMainStatusTab={Model.SelectedBAMainStatusTab}&{fyParams}{collapsedParam}{contextParams}"
        : $"?SelectedBAMainStatusTab={Model.SelectedBAMainStatusTab}&{fyParams}{collapsedParam}{contextParams}&ShowOverdueOnly=true";
}

<div class="tab-bar-row">
    <div class="ba-tab-spacer"></div>
    <ul class="nav nav-tabs mb-0">
        @foreach (var tab in tabs)
        {
            var isActive = (string.IsNullOrEmpty(tab.Value) && string.IsNullOrEmpty(Model.SelectedBAMainStatusTab))
                        || tab.Value == Model.SelectedBAMainStatusTab;
            var tabCount = Model.TabCounts.GetValueOrDefault(tab.Value, 0);
            var isAllTab = tab.Value == "All";
            var liClass = isAllTab ? "nav-item tab-all-separator" : "nav-item";
            var badgeClass = isAllTab ? "badge badge-ghost" : "badge bg-secondary ms-1";
            bool carryOverdue = tab.Value != "Approved" && Model.ShowOverdueOnly;
            var href = $"?SelectedBAMainStatusTab={tab.Value}&{fyParams}{collapsedParam}{contextParams}" +
                       (carryOverdue ? "&ShowOverdueOnly=true" : "");
            <li class="@liClass">
                <a class="nav-link @(isActive ? "active" : "")" href="@href">
                    @tab.Label
                    @if (tabCount > 0)
                    {
                        <span class="@badgeClass">@tabCount</span>
                    }
                </a>
            </li>
        }
    </ul>
    <div class="ba-tab-right">
        @if (isEligible)
        {
            <a href="@toggleHref" class="ba-overdue-switch @(Model.ShowOverdueOnly ? "ba-overdue-switch--on" : "")" aria-label="Show overdue only">
                <div class="ba-switch-track">
                    <div class="ba-switch-thumb"></div>
                </div>
                <span class="ba-switch-label">Overdue only</span>
            </a>
        }
    </div>
</div>

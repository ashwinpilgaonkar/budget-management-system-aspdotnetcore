@page "/activitylog"
@model ActivityLogModel
@{
    ViewData["Title"] = "Activity Log";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
    <div class="card mb-4 card-macos" style="border-radius: 10px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 10px;">
                <h3 class="page-title">User Activity Log</h3>
                <form method="post" asp-page-handler="ExportToExcelActivityLog" id="activityLogExportForm">
                    <button type="submit" class="btn btn-outline-success" id="activityLogExportBtn"
                            onclick="triggerExport('activityLogExportForm', 'activityLogExportBtn')">
                        <i class="fas fa-file-excel me-1"></i> Export
                    </button>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover text-center">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UserActivityLogs != null && Model.UserActivityLogs.Any())
                        {
                            int index = (Model.CurrentPage - 1) * Model.ResultsPerPage + 1;
                            foreach (var log in Model.UserActivityLogs)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@log.User.FirstName @log.User.LastName</td>
                                    <td>@log.Category</td>
                                    <td>@log.Description</td>
                                    <td>@log.Timestamp.ToString("g")</td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted mb-0">No records found</p>
                                        <small class="text-muted">Perform an action to record user activity</small>
                                    </div>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
            <partial name="_Pagination" model="Model.GetActivityLogPagination()" />
        </div>
    </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showExportToast() {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-success alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-check-circle me-2"></i> Your file is downloading. <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const container = document.querySelector('.container-fluid');
            const main = container.querySelector('main[role="main"]');
            container.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function triggerExport(formId, btnId) {
            const btn = document.getElementById(btnId);
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Exporting...';
            setTimeout(function () {
                btn.innerHTML = originalHtml;
                showExportToast();
            }, 2000);
        }
    </script>
}

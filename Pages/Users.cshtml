@page "/users"
@using budget_management_system_aspdotnetcore.Entities
@model UsersModel
@{
    ViewData["Title"] = "Users";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
    <!-- User List Card -->
    <div class="card mb-4 card-macos" style="border-radius: 10px;">
        <div class="card-body">
            <h3 class="page-title">Users</h3>
            <div class="d-flex gap-2 mb-3 align-items-center">
                <form method="get" class="flex-grow-1">
                    <div class="input-group search-group">
                        <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                        <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                        <input type="hidden" name="SortColumn" value="@Model.SortColumn" />
                        <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                        <input type="text" name="UserSearchTerm" class="form-control" placeholder="Search..." value="@Model.UserSearchTerm" />
                        <button type="submit" class="btn btn-outline-secondary border-start-0" style="color: #6c757d;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
                @if (!string.IsNullOrEmpty(Model.UserSearchTerm) || !string.IsNullOrEmpty(Model.UserStatusFilter) || Model.UserRoleIdFilter.HasValue)
                {
                    <a href="/users" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-1"></i> Clear filters
                    </a>
                }
                <form method="post" asp-page-handler="ExportToExcelUsers" id="usersExportForm">
                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                    <input type="hidden" name="ExportAll" value="false" id="usersExportAllFlag" />
                    <div class="btn-group">
                        <button type="submit" class="btn btn-outline-success" id="usersExportBtn"
                                onclick="triggerExport('usersExportForm', 'usersExportBtn', 'usersExportAllFlag', false)">
                            <i class="fas fa-file-excel me-1"></i> Export
                        </button>
                        <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle Dropdown</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#"
                                   onclick="triggerExport('usersExportForm', 'usersExportBtn', 'usersExportAllFlag', true); return false;">
                                    <i class="fas fa-table me-2"></i>Export All
                                </a>
                            </li>
                        </ul>
                    </div>
                </form>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
                    Add New +
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover text-center">
                    <thead>
                        <tr>
                            <th>
                                #
                            </th>
                            <th>
                                Email
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="User" />
                                    <input type="hidden" name="column" value="Email" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("Email")" />
                                    <input type="hidden" name="userPageNumber" value="@Model.UserCurrentPage" />
                                    <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("Email")"></i>
                                    </button>
                                </form>
                            </th>
                            <th>
                                First Name
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="User" />
                                    <input type="hidden" name="column" value="FirstName" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("FirstName")" />
                                    <input type="hidden" name="userPageNumber" value="@Model.UserCurrentPage" />
                                    <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("FirstName")"></i>
                                    </button>
                                </form>
                            </th>
                            <th>
                                Last Name
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="User" />
                                    <input type="hidden" name="column" value="LastName" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("LastName")" />
                                    <input type="hidden" name="userPageNumber" value="@Model.UserCurrentPage" />
                                    <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("LastName")"></i>
                                    </button>
                                </form>
                            </th>
                            <th>
                                Status
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="User" />
                                    <input type="hidden" name="column" value="Status" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("Status")" />
                                    <input type="hidden" name="userPageNumber" value="@Model.UserCurrentPage" />
                                    <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("Status")"></i>
                                    </button>
                                </form>
                                <div class="dropdown d-inline">
                                    <button class="btn btn-sm btn-light" type="button" id="userStatusFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                            style="@(!string.IsNullOrEmpty(Model.UserStatusFilter) ? "color: #0d6efd;" : "")">
                                        <i class="fas fa-filter"></i>
                                    </button>
                                    <div class="dropdown-menu p-3 shadow-lg" style="min-width: 200px;">
                                        <form method="get" id="userStatusFilterForm">
                                            <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                            <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                            <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                            <input type="hidden" name="SortColumn" value="@Model.SortColumn" />
                                            <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                                            <label class="form-label small fw-semibold mb-1">Filter by Status</label>
                                            <select name="UserStatusFilter" class="form-select form-select-sm" id="userStatusSelect">
                                                <option value="">All</option>
                                                <option value="active" selected="@(Model.UserStatusFilter == "active" ? "selected" : null)">Active</option>
                                                <option value="inactive" selected="@(Model.UserStatusFilter == "inactive" ? "selected" : null)">Inactive</option>
                                            </select>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                                                <button type="button" class="btn btn-sm btn-secondary" onclick="resetUserStatusFilter()">Reset</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </th>
                            <th>
                                Role
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="User" />
                                    <input type="hidden" name="column" value="Role" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("Role")" />
                                    <input type="hidden" name="userPageNumber" value="@Model.UserCurrentPage" />
                                    <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                    <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                    <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                    <input type="hidden" name="UserRoleIdFilter" value="@Model.UserRoleIdFilter" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("Role")"></i>
                                    </button>
                                </form>
                                <div class="dropdown d-inline">
                                    <button class="btn btn-sm btn-light" type="button" id="userRoleFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                                            style="@(Model.UserRoleIdFilter.HasValue ? "color: #0d6efd;" : "")">
                                        <i class="fas fa-filter"></i>
                                    </button>
                                    <div class="dropdown-menu p-3 shadow-lg" style="min-width: 220px;">
                                        <form method="get" id="userRoleFilterForm">
                                            <input type="hidden" name="UserSearchTerm" value="@Model.UserSearchTerm" />
                                            <input type="hidden" name="UserStatusFilter" value="@Model.UserStatusFilter" />
                                            <input type="hidden" name="userResultsPerPage" value="@Model.UserResultsPerPage" />
                                            <input type="hidden" name="SortColumn" value="@Model.SortColumn" />
                                            <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                                            <label class="form-label small fw-semibold mb-1">Filter by Role</label>
                                            <select name="UserRoleIdFilter" class="form-select form-select-sm" id="userRoleSelect">
                                                <option value="">All</option>
                                                @if (Model.UserRoleOptions != null)
                                                {
                                                    @foreach (var role in Model.UserRoleOptions)
                                                    {
                                                        <option value="@role.Value" selected="@(Model.UserRoleIdFilter?.ToString() == role.Value ? "selected" : null)">@role.Text</option>
                                                    }
                                                }
                                            </select>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                                                <button type="button" class="btn btn-sm btn-secondary" onclick="resetUserRoleFilter()">Reset</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </th>
                            <th>
                                Departments Responsible for
                            </th>

                            <th colspan="2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users != null && Model.Users.Any())
                        {
                            int index = (Model.UserCurrentPage - 1) * Model.UserResultsPerPage + 1;
                            @foreach (var user in Model.Users)
                            {
                                if (Model.EditingUserID == user.UserId)
                                {
                                    <!-- Editing row (no modal) -->
                                    <tr>
                                        <form method="post" asp-route-id="@user.UserId">
                                            <input type="hidden" asp-for="NewUser.UserId" value="@user.UserId" />
                                            <td>@index</td>
                                            <td><input asp-for="NewUser.Email" value="@user.Email" class="form-control" /></td>
                                            <td><input asp-for="NewUser.FirstName" value="@user.FirstName" class="form-control" /></td>
                                            <td><input asp-for="NewUser.LastName" value="@user.LastName" class="form-control" /></td>
                                            <td>
                                                <select asp-for="NewUser.Status" class="form-control" asp-items="Model.UserStatusOptions"></select>
                                            </td>
                                            <td>
                                                <select asp-for="NewUser.RoleID" class="form-control" asp-items="Model.UserRoleOptions"></select>
                                            </td>
                                            <td>
                                                <select asp-for="SelectedDepartmentIds"
                                                        class="selectpicker w-100"
                                                        multiple
                                                        data-live-search="true"
                                                        title="Select departments">
                                                    @foreach (var dept in Model.DepartmentOptions)
                                                    {
                                                        <option value="@dept.Value"
                                                                selected="@(Model.SelectedDepartmentIds.Contains(int.Parse(dept.Value)) ? "selected" : null)"
                                                                data-tokens="@dept.Text">
                                                            @dept.Text
                                                        </option>
                                                    }
                                                </select>
                                            </td>
                                                <td>
                                                <div class="d-flex justify-content-evenly">
                                                    <button type="submit" asp-page-handler="SaveUser" asp-route-id="@user.UserId" class="btn btn-success" onclick="return confirm('Save changes to this user?')">Save</button>
                                                    <button type="submit" asp-page-handler="CancelEditUser" asp-route-id="@user.UserId" class="btn btn-secondary" onclick="return confirm('Cancel editing? Unsaved changes will be lost.')">Cancel</button>
                                                </div>
                                            </td>
                                        </form>
                                    </tr>
                                }
                                else
                                {
                                    <!-- Display Mode -->
                                    <tr>
                                        <td>@index</td>
                                        <td>@user.Email</td>
                                        <td>@user.FirstName</td>
                                        <td>@user.LastName</td>
                                        <td>
                                            @if (user.Status == UserStatus.active)
                                            {
                                                <span class="badge text-bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>@user.Role.RoleName</td>
                                        <td>
                                            @foreach (var d in user.DepartmentsResponsibleFor)
                                            {
                                                <div>@d.DepartmentName</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-evenly gap-3">
                                                <form method="post" asp-page-handler="EditUser" asp-route-id="@user.UserId">
                                                    <button type="submit" class="btn btn-outline-secondary">Edit</button>
                                                </form>
                                                <form method="post" asp-page-handler="DeleteUser" asp-route-id="@user.UserId"
                                                      onsubmit="return confirm('Delete user \'@user.FirstName @user.LastName\'? This cannot be undone.')">
                                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                index++;
                            }
                        } else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <div class="py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted mb-0">No records found</p>
                                        <small class="text-muted">Click the Add New + button to create a new user</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Users != null && Model.Users.Any())
            {
                var userPagination = new budget_management_system_aspdotnetcore.ViewModels.PaginationViewModel
                {
                    CurrentPage = Model.UserCurrentPage,
                    TotalPages = Model.UserTotalPages,
                    TotalRecords = Model.TotalUsers,
                    ResultsPerPage = Model.UserResultsPerPage,
                    PageSizes = Model.PageSizes,
                    AriaLabel = "User page navigation",
                    PrevUrl = Url.Page(null, new { userPageNumber = Model.UserCurrentPage - 1, userResultsPerPage = Model.UserResultsPerPage, UserSearchTerm = Model.UserSearchTerm, UserStatusFilter = Model.UserStatusFilter, UserRoleIdFilter = Model.UserRoleIdFilter, SortColumn = Model.SortColumn, SortOrder = Model.SortOrder }),
                    NextUrl = Url.Page(null, new { userPageNumber = Model.UserCurrentPage + 1, userResultsPerPage = Model.UserResultsPerPage, UserSearchTerm = Model.UserSearchTerm, UserStatusFilter = Model.UserStatusFilter, UserRoleIdFilter = Model.UserRoleIdFilter, SortColumn = Model.SortColumn, SortOrder = Model.SortOrder }),
                    SizeChangeUrlTemplate = Url.Page(null, new { userPageNumber = 1, userResultsPerPage = "__SIZE__", UserSearchTerm = Model.UserSearchTerm, UserStatusFilter = Model.UserStatusFilter, UserRoleIdFilter = Model.UserRoleIdFilter, SortColumn = Model.SortColumn, SortOrder = Model.SortOrder })
                };
                <partial name="_Pagination" model="userPagination" />
            }
        </div>
    </div>


        </div>
    </div>

    <!-- Add User Modal -->
    <div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addUserModalLabel">Add New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-page-handler="AddUser">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.Email" class="form-label">Email: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewUser.Email" class="form-control" type="email" required />
                                <span asp-validation-for="NewUser.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.Password" class="form-label">Password: <span class="text-danger ms-1">*</span></label>
                                <div class="input-group">
                                    <input asp-for="NewUser.Password" type="password" class="form-control" id="passwordInput" required minlength="6" />
                                    <button class="btn" type="button" id="togglePasswordBtn" tabindex="-1"
                                            style="border-color: #ced4da; border-left: none; background: white; color: #6c757d;">
                                        <i class="fas fa-eye" id="togglePasswordIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="NewUser.Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.Status" class="form-label">Status: <span class="text-danger ms-1">*</span></label>
                                <select asp-for="NewUser.Status" class="form-control">
                                    <option value="active">active</option>
                                    <option value="inactive">inactive</option>
                                </select>
                                <span asp-validation-for="NewUser.Status" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.RoleID" class="form-label">Role: <span class="text-danger ms-1">*</span></label>
                                <select asp-for="NewUser.RoleID" class="form-control" asp-items="Model.UserRoleOptions">
                                </select>
                                <span asp-validation-for="NewUser.RoleID" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.FirstName" class="form-label">First Name: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewUser.FirstName" class="form-control" required />
                                <span asp-validation-for="NewUser.FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewUser.LastName" class="form-label">Last Name: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewUser.LastName" class="form-control" required />
                                <span asp-validation-for="NewUser.LastName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SelectedDepartmentIds" class="form-label">Departments Responsible For: <span class="text-danger ms-1">*</span></label>

                                <select asp-for="SelectedDepartmentIds"
                                        class="selectpicker w-100"
                                        multiple
                                        data-live-search="true"
                                        title="Select departments"
                                        id="addUserDepartments">
                                    @foreach (var department in Model.DepartmentOptions)
                                    {
                                        <option value="@department.Value" data-tokens="@department.Text">
                                            @department.Text
                                        </option>
                                    }
                                </select>
                                <span class="text-danger" id="addUserDepartmentsError" style="display:none;">At least one department is required.</span>
                                <span asp-validation-for="SelectedDepartmentIds" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Add</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function resetUserStatusFilter() {
            document.getElementById('userStatusSelect').value = '';
            document.getElementById('userStatusFilterForm').submit();
        }

        function resetUserRoleFilter() {
            document.getElementById('userRoleSelect').value = '';
            document.getElementById('userRoleFilterForm').submit();
        }

        document.addEventListener('DOMContentLoaded', function () {
            ['#userStatusFilterDropdown', '#userRoleFilterDropdown'].forEach(function (id) {
                const menu = document.querySelector(id + ' + .dropdown-menu');
                if (menu) menu.addEventListener('click', function (e) { e.stopPropagation(); });
            });
        });
    </script>
    <script>
        document.getElementById('togglePasswordBtn').addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('togglePasswordIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });

        document.querySelector('#addUserModal form').addEventListener('submit', function (e) {
            const selected = document.getElementById('addUserDepartments').selectedOptions;
            const error = document.getElementById('addUserDepartmentsError');
            if (selected.length === 0) {
                e.preventDefault();
                error.style.display = 'block';
            } else {
                error.style.display = 'none';
            }
        });

        function showExportToast() {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-success alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-check-circle me-2"></i> Your file is downloading. <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const container = document.querySelector('.container-fluid');
            const main = container.querySelector('main[role="main"]');
            container.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function triggerExport(formId, btnId, flagId, exportAll) {
            const btn = document.getElementById(btnId);
            const flag = document.getElementById(flagId);
            flag.value = exportAll ? 'true' : 'false';
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Exporting...';
            setTimeout(function () {
                btn.innerHTML = originalHtml;
                flag.value = 'false';
                showExportToast();
            }, 2000);
            if (exportAll) {
                document.getElementById(formId).submit();
            }
        }
    </script>
}

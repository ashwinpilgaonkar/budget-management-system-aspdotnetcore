@page "/departments"
@model DepartmentsModel
@{
    ViewData["Title"] = "Departments";
}

<div class="container">

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
    <!-- Department List Card -->
    <div class="card mb-4 shadow-sm" style="border-radius: 10px;">
        <div class="card-body">
            <h3 class="page-title">Departments</h3>
            <div class="d-flex gap-2 mb-3 align-items-center">
                <form method="get" class="flex-grow-1">
                    <div class="input-group search-group">
                        <input type="text" name="DepartmentSearchTerm" class="form-control" placeholder="Search..." value="@Model.DepartmentSearchTerm" />
                        <button type="submit" class="btn btn-outline-secondary border-start-0" style="color: #6c757d;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
                <form method="post" asp-page-handler="ExportToExcelDepartments" id="deptsExportForm">
                    <input type="hidden" name="DepartmentSearchTerm" value="@Model.DepartmentSearchTerm" />
                    <input type="hidden" name="DepartmentMinBudget" value="@Model.DepartmentMinBudget" />
                    <input type="hidden" name="DepartmentMaxBudget" value="@Model.DepartmentMaxBudget" />
                    <input type="hidden" name="ExportAll" value="false" id="deptsExportAllFlag" />
                    <div class="btn-group">
                        <button type="submit" class="btn btn-outline-success" id="deptsExportBtn"
                                onclick="triggerExport('deptsExportForm', 'deptsExportBtn', 'deptsExportAllFlag', false)">
                            <i class="fas fa-file-excel me-1"></i> Export
                        </button>
                        <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle Dropdown</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#"
                                   onclick="triggerExport('deptsExportForm', 'deptsExportBtn', 'deptsExportAllFlag', true); return false;">
                                    <i class="fas fa-table me-2"></i>Export All
                                </a>
                            </li>
                        </ul>
                    </div>
                </form>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDepartmentModal">
                    Add New +
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover text-center">
                    <thead>
                        <tr>
                            <th>
                                #
                            </th>
                            <th>
                                Department Name
                                <form method="get" class="d-inline">
                                    <input type="hidden" name="handler" value="SortColumn" />
                                    <input type="hidden" name="table" value="Department" />
                                    <input type="hidden" name="column" value="DepartmentName" />
                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("DepartmentName")" />
                                    <input type="hidden" name="departmentPageNumber" value="@Model.DepartmentCurrentPage" />
                                    <input type="hidden" name="departmentResultsPerPage" value="@Model.DepartmentResultsPerPage" />
                                    <input type="hidden" name="DepartmentSearchTerm" value="@Model.DepartmentSearchTerm" />
                                    <button type="submit" class="btn btn-link p-0">
                                        <i class="fas @Model.GetSortIcon("DepartmentName")"></i>
                                    </button>
                                </form>
                            </th>
                            <th>SpeedType</th>
                            <th>
                                Budget
                                <div class="dropdown d-inline">
                                    <button class="btn btn-sm btn-light dropdown-toggle" type="button" id="departmentBudgetFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fas fa-filter"></i>
                                    </button>

                                    <div class="dropdown-menu p-3 shadow-lg" style="min-width: 250px;">
                                        <form method="get" id="departmentBudgetFilterForm">
                                            <div class="mb-2">
                                                <label class="form-label">Min Budget (Total)</label>
                                                <input type="number" step="0.01" name="DepartmentMinBudget" id="departmentMinBudgetInput" class="form-control form-control-sm"
                                                       value="@(Model.DepartmentMinBudget?.ToString("0.##") ?? "")" />
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label">Max Budget (Total)</label>
                                                <input type="number" step="0.01" name="DepartmentMaxBudget" id="departmentMaxBudgetInput" class="form-control form-control-sm"
                                                       value="@(Model.DepartmentMaxBudget?.ToString("0.##") ?? "")" />
                                            </div>

                                            <div class="d-flex justify-content-start gap-2 mt-3">
                                                <button type="submit" class="btn btn-sm btn-primary" id="departmentFilterApplyButton" disabled>Apply</button>
                                                <button type="button" class="btn btn-sm btn-secondary" onclick="resetDepartmentBudgetFields()">Reset</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </th>
                            <th colspan="2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Departments != null)
                        {
                            int index = 1;
                            @foreach (var dept in Model.Departments)
                            {
                                if (Model.EditingDepartmentID == dept.DepartmentID)
                                {
                                    <tr>
                                        <form method="post" asp-route-id="@dept.DepartmentID">
                                        <input type="hidden" asp-for="NewDepartment.DepartmentID" value="@dept.DepartmentID" />
                                        <td>@index</td>
                                        <td><input asp-for="NewDepartment.DepartmentName" value="@dept.DepartmentName" class="form-control" /></td>
                                        <td>
                                            <select asp-for="SelectedSpeedTypeIds" class="selectpicker w-100" multiple data-live-search="true" title="Select speed types">
                                                @foreach (var speedtype in Model.SpeedTypes)
                                                {
                                                    <option value="@speedtype.SpeedTypeId"
                                                            selected="@(Model.SelectedSpeedTypeIds.Contains(speedtype.SpeedTypeId) ? "selected" : null)"
                                                            data-tokens="@speedtype.Code">
                                                        @speedtype.Code
                                                    </option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            @foreach (var deptSpeedType in dept.DepartmentSpeedTypes)
                                            {
                                                <p>$@deptSpeedType.SpeedType.Budget.ToString("N2")</p>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-evenly">
                                                <button type="submit" asp-page-handler="SaveDepartment" asp-route-id="@dept.DepartmentID" class="btn btn-success" onclick="return confirm('//Are you sure you want to save these changes?')">Save</button>
                                                <button type="submit" asp-page-handler="CancelEditDepartment" asp-route-id="@dept.DepartmentID" class="btn btn-secondary" onclick="return confirm('Are you sure you want to cancel editing? Unsaved changes will be lost.')">Cancel</button>
                                            </div>
                                        </td>
                                        </form>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td>@dept.DepartmentName</td>
                                        <td>
                                            @foreach (var deptSpeedType in dept.DepartmentSpeedTypes)
                                            {
                                                <p>@deptSpeedType.SpeedType.Code</p>
                                            }
                                        </td>
                                        <td>
                                            @foreach (var deptSpeedType in dept.DepartmentSpeedTypes)
                                            {
                                                <p>$@deptSpeedType.SpeedType.Budget.ToString("N2")</p>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-evenly gap-3">
                                                <form method="post" asp-page-handler="EditDepartment" asp-route-id="@dept.DepartmentID">
                                                    <button type="submit" class="btn btn-outline-secondary">Edit</button>
                                                </form>
                                                <form method="post" asp-page-handler="DeleteDepartment" asp-route-id="@dept.DepartmentID"
                                                      onsubmit="return confirm('Delete department \'@dept.DepartmentName\'? This cannot be undone.')">
                                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                index++;
                            }
                        }

                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted mb-0">No records found</p>
                                        <small class="text-muted">Click the Add New + button to create a new department</small>
                                    </div>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>

            @if (Model.Departments != null)
            {
                var deptPagination = new budget_management_system_aspdotnetcore.ViewModels.PaginationViewModel
                {
                    CurrentPage = Model.DepartmentCurrentPage,
                    TotalPages = Model.DepartmentTotalPages,
                    TotalRecords = Model.TotalDepartments,
                    ResultsPerPage = Model.DepartmentResultsPerPage,
                    PageSizes = Model.PageSizes,
                    AriaLabel = "Department page navigation",
                    PrevUrl = Url.Page(null, new { departmentPageNumber = Model.DepartmentCurrentPage - 1, departmentResultsPerPage = Model.DepartmentResultsPerPage, departmentSearchTerm = Model.DepartmentSearchTerm, departmentMinBudget = Model.DepartmentMinBudget, departmentMaxBudget = Model.DepartmentMaxBudget }),
                    NextUrl = Url.Page(null, new { departmentPageNumber = Model.DepartmentCurrentPage + 1, departmentResultsPerPage = Model.DepartmentResultsPerPage, departmentSearchTerm = Model.DepartmentSearchTerm, departmentMinBudget = Model.DepartmentMinBudget, departmentMaxBudget = Model.DepartmentMaxBudget }),
                    SizeChangeUrlTemplate = Url.Page(null, new { departmentPageNumber = 1, departmentResultsPerPage = "__SIZE__", departmentSearchTerm = Model.DepartmentSearchTerm, departmentMinBudget = Model.DepartmentMinBudget, departmentMaxBudget = Model.DepartmentMaxBudget })
                };
                <partial name="_Pagination" model="deptPagination" />
            }
        </div>
    </div>

        </div>
    </div>

    <!-- Add Department Modal -->
    <div class="modal fade" id="addDepartmentModal" tabindex="-1" aria-labelledby="addDepartmentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addDepartmentModalLabel">Add New Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-page-handler="AddDepartment">
                        <div class="mb-3">
                            <label asp-for="NewDepartment.DepartmentName" class="form-label">Department Name: <span class="text-danger ms-1">*</span></label>
                            <input asp-for="NewDepartment.DepartmentName" class="form-control" required />
                            <span asp-validation-for="NewDepartment.DepartmentName" class="text-danger"></span>
                        </div>
                        <div class="mb-3 d-flex flex-column">
                            <label asp-for="SelectedSpeedTypeIds" class="form-label">SpeedTypes: <span class="text-danger ms-1">*</span></label>
                            <select asp-for="SelectedSpeedTypeIds" class="selectpicker w-100" multiple data-live-search="true" title="Select speed types" id="addDeptSpeedTypes">
                                @foreach (var speedtype in Model.SpeedTypes)
                                {
                                    <option value="@speedtype.SpeedTypeId" data-tokens="@speedtype.Code">
                                        @speedtype.Code
                                    </option>
                                }
                            </select>
                            <span class="text-danger" id="addDeptSpeedTypesError" style="display:none;">At least one SpeedType is required.</span>
                            <span asp-validation-for="SelectedSpeedTypeIds" class="text-danger"></span>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Add</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>


<script>
    const departmentMinInput = document.getElementById('departmentMinBudgetInput');
    const departmentMaxInput = document.getElementById('departmentMaxBudgetInput');
    const departmentApplyButton = document.getElementById('departmentFilterApplyButton');
    const departmentForm = document.getElementById("departmentBudgetFilterForm");

    function updateApplyButtonState() {
        departmentApplyButton.disabled = !departmentMinInput.value && !departmentMaxInput.value;
    }

    function resetDepartmentBudgetFields() {
        departmentMinInput.value = '';
        departmentMaxInput.value = '';
        updateApplyButtonState();
        departmentForm.submit();
    }

    departmentMinInput.addEventListener('input', updateApplyButtonState);
    departmentMaxInput.addEventListener('input', updateApplyButtonState);

    // Run on load
    updateApplyButtonState();

    document.addEventListener('DOMContentLoaded', function () {
    const departmentDropdownMenu = document.querySelector('#departmentBudgetFilterDropdown + .dropdown-menu');

        if (departmentDropdownMenu) {
            departmentDropdownMenu.addEventListener('click', function (e) {
                    e.stopPropagation(); // Prevents the dropdown from closing on click inside
                });
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        const addDeptForm = document.querySelector('#addDepartmentModal form');
        const speedTypesError = document.getElementById('addDeptSpeedTypesError');

        addDeptForm.addEventListener('submit', function (e) {
            const selected = document.getElementById('addDeptSpeedTypes').selectedOptions;
            if (selected.length === 0) {
                e.preventDefault();
                speedTypesError.style.display = 'block';
            } else {
                speedTypesError.style.display = 'none';
            }
        });
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showExportToast() {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-success alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-check-circle me-2"></i> Your file is downloading. <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const container = document.querySelector('.container-fluid');
            const main = container.querySelector('main[role="main"]');
            container.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function triggerExport(formId, btnId, flagId, exportAll) {
            const btn = document.getElementById(btnId);
            const flag = document.getElementById(flagId);
            flag.value = exportAll ? 'true' : 'false';
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Exporting...';
            setTimeout(function () {
                btn.innerHTML = originalHtml;
                flag.value = 'false';
                showExportToast();
            }, 2000);
            if (exportAll) {
                document.getElementById(formId).submit();
            }
        }
    </script>
}

                                                                                                    || (amendment.Status == AmendmentStatus.Submitted && !String.Equals(userRole, RoleConstants.AFOIdString));
                                                                                            }
                                                                                            @if (!String.Equals(userRole, RoleConstants.AFOIdString) || amendment.Status == AmendmentStatus.Draft || amendment.Status == AmendmentStatus.Rejected)
                                                                                            {
                                                                                                <div class="d-flex justify-content-evenly gap-2">

                                                                    CurrentPage = Model.BudgetAmendmentCurrentPage,
                                                                    TotalPages = Model.BudgetAmendmentTotalPages,
                                                                    TotalRecords = Model.TotalBudgetAmendments,
                                                                    ResultsPerPage = Model.BudgetAmendmentResultsPerPage,
                                                                    PageSizes = Model.PageSizes,

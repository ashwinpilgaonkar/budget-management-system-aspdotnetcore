                                                                                        <td><input asp-for="NewBudgetAmendment.DepartmentID" value="@amendment.DepartmentID" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.ProgramCode" value="@amendment.ProgramCode" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.ClassCode" value="@amendment.ClassCode" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.AcctDescription" value="@amendment.AcctDescription" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.BudgetCode" value="@amendment.BudgetCode" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.PositionNumber" value="@amendment.PositionNumber" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.AmountIncrease" value="@amendment.AmountIncrease" class="form-control" form="@editFormId" /></td>
                                                                                        <td><input asp-for="NewBudgetAmendment.AmountDecrease" value="@amendment.AmountDecrease" class="form-control" form="@editFormId" /></td>
                                                                                        @if (!String.Equals(userRole, RoleConstants.AFOIdString))
                                                                                        {
                                                                                            <td>@(amendment.CreatedByUser?.Email ?? "N/A") <br> at <br> @(amendment.CreatedAt?.ToString("MM/dd/yy HH:mm") ?? "N/A")</td>

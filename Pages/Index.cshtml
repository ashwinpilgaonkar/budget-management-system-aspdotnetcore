            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addAmendmentModalLabel">Create New Budget Amendment Entry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-page-handler="AddAmendment">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.CategoryName" class="form-label">Category Name: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewBudgetAmendment.CategoryName" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.AdjustmentDetail" class="form-label">Adjustment Detail: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewBudgetAmendment.AdjustmentDetail" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3 d-flex flex-column">
                                <label asp-for="SourceSpeedtype" class="form-label">Source SpeedType: <span class="text-danger ms-1">*</span></label>
                                <select asp-for="SourceSpeedtype" class="selectpicker w-100" data-live-search="true" id="sourceSpeedtype">
                                    @foreach (var speedtype in Model.SpeedTypes)
                                    {
                                        <option value="@speedtype.SpeedTypeId" data-tokens="@speedtype.Code" data-fundcode="@speedtype.FundCode" data-programcode="@speedtype.ProgramCode" data-classcode="@speedtype.ClassCode">
                                            @speedtype.Code
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3 d-flex flex-column">
                                <label asp-for="DestinationSpeedtype" class="form-label">Destination SpeedType: <span class="text-danger ms-1">*</span></label>
                                <select asp-for="DestinationSpeedtype" class="selectpicker w-100" data-live-search="true" id="destinationSpeedtype">
                                    @foreach (var speedtype in Model.SpeedTypes)
                                    {
                                        <option value="@speedtype.SpeedTypeId" data-tokens="@speedtype.Code">
                                            @speedtype.Code
                                        </option>
                                    }
                                </select>
                                <div class="invalid-feedback" id="speedtypeError">Destination SpeedType must be different from Source SpeedType.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.FundCode" class="form-label">Fund Code:</label>
                                <input asp-for="NewBudgetAmendment.FundCode" class="form-control" id="fundCode" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.DepartmentID" class="form-label">Department ID:</label>
                                <input asp-for="NewBudgetAmendment.DepartmentID" class="form-control" value="@Model.SelectedDepartmentID" readonly />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.ProgramCode" class="form-label">Program Code:</label>
                                <input asp-for="NewBudgetAmendment.ProgramCode" class="form-control" id="programCode" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.ClassCode" class="form-label">Class Code:</label>
                                <input asp-for="NewBudgetAmendment.ClassCode" class="form-control" id="classCode" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.AcctDescription" class="form-label">Account Description: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewBudgetAmendment.AcctDescription" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.BudgetCode" class="form-label">Budget Code: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewBudgetAmendment.BudgetCode" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NewBudgetAmendment.PositionNumber" class="form-label">Position Number: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="NewBudgetAmendment.PositionNumber" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TransferAmount" class="form-label">Amount: <span class="text-danger ms-1">*</span></label>
                                <input asp-for="TransferAmount" class="form-control" type="number" step="0.01" min="0.01" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <input asp-for="NewBudgetAmendment.BudgetAmendmentMainID" type="hidden" class="form-control" value="@Model.SelectedBudgetAmendmentMainID" readonly />
                            </div>
                        </div>
                        <partial name="_FilterState" model="Model.FilterState" />
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Create Draft</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showErrorToast(msg) {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-danger alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i> ' + msg + ' <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const main = document.querySelector('main[role="main"]');
            main.parentElement.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function validateAmendmentSave(formId) {
            const form = document.getElementById(formId);
            if (!form) return true;
            const fields = [
                { id: 'NewBudgetAmendment_CategoryName', label: 'Category Name' },
                { id: 'NewBudgetAmendment_AdjustmentDetail', label: 'Adjustment Detail' },
                { id: 'NewBudgetAmendment_AcctDescription', label: 'Account Description' },
                { id: 'NewBudgetAmendment_BudgetCode', label: 'Budget Code' },
                { id: 'NewBudgetAmendment_PositionNumber', label: 'Position Number' }
            ];
            for (const f of fields) {
                const el = document.getElementById(f.id);
                if (!el || !el.value.trim()) {
                    showErrorToast('All fields are required to save a Budget Amendment entry.');
                    return false;
                }
            }
            const amountEl = document.getElementById('NewBudgetAmendment_AmountIncrease');
            if (!amountEl || parseFloat(amountEl.value) <= 0) {
                showErrorToast('All fields are required to save a Budget Amendment entry.');
                return false;
            }
            return confirm('Save changes to this entry?');
        }

        function showExportToast() {
            const alertEl = document.createElement('div');
            alertEl.className = 'alert alert-success alert-dismissible fade show';
            alertEl.setAttribute('role', 'alert');
            alertEl.style.cssText = 'width: fit-content; max-width: 600px; margin-left: auto; margin-right: auto;';
            alertEl.innerHTML = '<i class="fas fa-check-circle me-2"></i> Your file is downloading. <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            const main = document.querySelector('main[role="main"]');
            main.parentElement.insertBefore(alertEl, main);
            setTimeout(function () { $(alertEl).alert('close'); }, 8000);
        }

        function triggerExport(formId, btnId, typeInputId, exportType) {
            const btn = document.getElementById(btnId);
            const typeInput = document.getElementById(typeInputId);
            typeInput.value = exportType;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Exporting...';
            setTimeout(function () {
                btn.innerHTML = originalHtml;
                typeInput.value = 'current';
                showExportToast();
            }, 2000);
            if (exportType !== 'current') {
                document.getElementById(formId).submit();
            }
        }

        function handleApproveAll(btn) {
            if (confirm('Are you sure you want to approve all these entries?')) {
                btn.closest('form').submit();
            }
        }

        window.addEventListener('beforeunload', function () {
            sessionStorage.setItem('scrollPosition', window.scrollY);
        });

        document.addEventListener('DOMContentLoaded', function () {
            // ----- Scroll restoration + accordion open -----
            const scrollPosition = sessionStorage.getItem('scrollPosition');
            const urlParams = new URLSearchParams(window.location.search);
            const selectedBA = urlParams.get('SelectedBudgetAmendmentMainID');
            const selectedDept = urlParams.get('SelectedDepartmentID');
            const accordion = document.getElementById('budgetAmendmentsAccordion');

            if (selectedBA && selectedDept) {
                const baAccordions = document.querySelectorAll('[id^="collapseBA"]');
                baAccordions.forEach(accordion => {
                    if (accordion.getAttribute('data-ba-id') == selectedBA) {
                        new bootstrap.Collapse(accordion, { show: true });

                        setTimeout(() => {
                            const deptAccordions = accordion.querySelectorAll('[data-dept-id]');
                            deptAccordions.forEach(deptAccordion => {
                                if (deptAccordion.getAttribute('data-dept-id') == selectedDept) {
                                    new bootstrap.Collapse(deptAccordion, { show: true });
                                }
                            });

                            setTimeout(() => {
                                if (scrollPosition) {
                                    window.scrollTo(0, parseInt(scrollPosition));
                                    sessionStorage.removeItem('scrollPosition');
                                }
                            }, 150);
                        }, 350);
                    }
                });
            } else {
                if (scrollPosition) {
                    window.scrollTo(0, parseInt(scrollPosition));
                    sessionStorage.removeItem('scrollPosition');
                }

                if (accordion) {
                    const currentTab = urlParams.get('SelectedBAMainStatusTab') || 'Submitted';
                    const savedState = sessionStorage.getItem('tabAccordionState_' + currentTab);
                    if (savedState) {
                        try {
                            const state = JSON.parse(savedState);
                            if (state.openBAIds && state.openBAIds.length > 0) {
                                state.openBAIds.forEach(function (baId) {
                                    const baCollapse = accordion.querySelector('[data-ba-id="' + baId + '"]');
                                    if (baCollapse) {
                                        new bootstrap.Collapse(baCollapse, { show: true });
                                        const deptIds = state.openDeptIds && state.openDeptIds[baId];
                                        if (deptIds && deptIds.length > 0) {
                                            setTimeout(function () {
                                                deptIds.forEach(function (deptId) {
                                                    const deptCollapse = baCollapse.querySelector('[data-dept-id="' + deptId + '"]');
                                                    if (deptCollapse) new bootstrap.Collapse(deptCollapse, { show: true });
                                                });
                                            }, 350);
                                        }
                                    }
                                });
                            }
                        } catch (e) {}
                    }
                }
            }

            // ----- SpeedType source/destination validation -----
            const sourceSpeedtype = document.getElementById('sourceSpeedtype');
            const destinationSpeedtype = document.getElementById('destinationSpeedtype');
            const speedtypeError = document.getElementById('speedtypeError');
            if (sourceSpeedtype && destinationSpeedtype) {
                const speedtypeForm = sourceSpeedtype.closest('form');

                function validateSpeedtypes() {
                    if (sourceSpeedtype.value && destinationSpeedtype.value && sourceSpeedtype.value === destinationSpeedtype.value) {
                        destinationSpeedtype.classList.add('is-invalid');
                        speedtypeError.style.display = 'block';
                        return false;
                    }
                    destinationSpeedtype.classList.remove('is-invalid');
                    speedtypeError.style.display = 'none';
                    return true;
                }

                $(sourceSpeedtype).on('changed.bs.select', validateSpeedtypes);
                $(destinationSpeedtype).on('changed.bs.select', validateSpeedtypes);

                speedtypeForm.addEventListener('submit', function (e) {
                    if (!validateSpeedtypes()) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });

                // ----- SpeedType field auto-population -----
                function populateFields() {
                    const selectedOption = sourceSpeedtype.options[sourceSpeedtype.selectedIndex];
                    document.getElementById('fundCode').value    = selectedOption.getAttribute('data-fundcode')    || '';
                    document.getElementById('programCode').value = selectedOption.getAttribute('data-programcode') || '';
                    document.getElementById('classCode').value   = selectedOption.getAttribute('data-classcode')   || '';
                }

                populateFields();
                sourceSpeedtype.addEventListener('change', populateFields);

                ['fundCode', 'programCode', 'classCode'].forEach(id => {
                    const field = document.getElementById(id);
                    if (field) {
                        field.setAttribute('readonly', true);
                        field.style.backgroundColor = '#f0f0f0';
                    }
                });
            }

            // ----- Financial year range toggle -----
            const fySelect = document.getElementById("financialYear");
            if (fySelect) toggleDateRange(fySelect.value);

            // ----- Dropdown click-through prevention -----
            ['#createdByFilterDropdown', '#editedByFilterDropdown', '#updatedByFilterDropdown'].forEach(function (selector) {
                const menu = document.querySelector(selector + ' + .dropdown-menu');
                if (menu) menu.addEventListener('click', function (e) { e.stopPropagation(); });
            });

            // ----- Collapse state management for tab bar, overdue toggle, FY filter, BA pagination -----
            function isBaMainCollapsed() {
                return !accordion || !accordion.querySelector(':scope > .accordion-item > .accordion-collapse.show');
            }

            function isBaDeptCollapsed() {
                if (!accordion) return true;
                for (const main of accordion.querySelectorAll(':scope > .accordion-item > .accordion-collapse.show')) {
                    if (main.querySelector('.accordion-collapse.show')) return false;
                }
                return true;
            }

            function applyCollapseState(url) {
                isBaMainCollapsed() ? url.searchParams.set('BAMainCollapsed', 'true') : url.searchParams.delete('BAMainCollapsed');
                isBaDeptCollapsed() ? url.searchParams.set('BADeptCollapsed', 'true')  : url.searchParams.delete('BADeptCollapsed');
            }

            function getOpenAccordionState() {
                const openBAIds = [];
                const openDeptIds = {};
                if (!accordion) return { openBAIds, openDeptIds };
                accordion.querySelectorAll(':scope > .accordion-item > .accordion-collapse.show').forEach(function (baCollapse) {
                    const baId = baCollapse.getAttribute('data-ba-id');
                    if (baId) {
                        openBAIds.push(baId);
                        openDeptIds[baId] = [];
                        baCollapse.querySelectorAll('.accordion-collapse.show[data-dept-id]').forEach(function (deptCollapse) {
                            const deptId = deptCollapse.getAttribute('data-dept-id');
                            if (deptId) openDeptIds[baId].push(deptId);
                        });
                    }
                });
                return { openBAIds, openDeptIds };
            }

            document.querySelectorAll('.tab-bar-row .nav-link').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();

                    const editingId = urlParams.get('EditingBudgetAmendmentID');
                    if (editingId && editingId !== '0') {
                        if (!confirm('Are you sure you want to cancel editing? Unsaved changes will be lost.')) {
                            return;
                        }
                    }

                    const currentTab = urlParams.get('SelectedBAMainStatusTab') || 'Submitted';
                    sessionStorage.setItem('tabAccordionState_' + currentTab, JSON.stringify(getOpenAccordionState()));

                    const url = new URL(this.href);
                    url.searchParams.set('BAMainCollapsed', 'true');
                    url.searchParams.set('BADeptCollapsed', 'true');
                    url.searchParams.delete('EditingBudgetAmendmentID');
                    url.searchParams.delete('SelectedDepartmentID');
                    url.searchParams.delete('SelectedBudgetAmendmentMainID');
                    window.location.href = url.toString();
                });
            });

            const overdueSwitch = document.querySelector('.ba-overdue-switch');
            if (overdueSwitch) {
                overdueSwitch.addEventListener('click', function (e) {
                    e.preventDefault();
                    const href = this.href;
                    const mainCollapsed = isBaMainCollapsed();
                    const deptCollapsed = isBaDeptCollapsed();
                    this.classList.toggle('ba-overdue-switch--on');
                    setTimeout(function () {
                        const url = new URL(href);
                        if (accordion) {
                            mainCollapsed ? url.searchParams.set('BAMainCollapsed', 'true') : url.searchParams.delete('BAMainCollapsed');
                            deptCollapsed ? url.searchParams.set('BADeptCollapsed', 'true')  : url.searchParams.delete('BADeptCollapsed');
                        }
                        window.location.href = url.toString();
                    }, 220);
                });
            }

            const fyForm = document.querySelector('form[method="get"]');
            if (fyForm) {
                fyForm.addEventListener('submit', function () {
                    [['BAMainCollapsed', isBaMainCollapsed()], ['BADeptCollapsed', isBaDeptCollapsed()]].forEach(function ([name, val]) {
                        let input = fyForm.querySelector(`input[name="${name}"]`);
                        if (!input) {
                            input = document.createElement('input');
                            input.type = 'hidden';
                            input.name = name;
                            fyForm.appendChild(input);
                        }
                        input.value = val ? 'true' : 'false';
                    });
                });
            }

            const baMainPagNav = document.querySelector('nav[aria-label="Budget amendment main page navigation"]');
            if (baMainPagNav && accordion) {
                baMainPagNav.querySelectorAll('a.page-link').forEach(function (link) {
                    link.addEventListener('click', function (e) {
                        if (this.getAttribute('href') === '#') return;
                        e.preventDefault();
                        const url = new URL(this.href);
                        applyCollapseState(url);
                        window.location.href = url.toString();
                    });
                });
            }
        });
    </script>
}


@page "/home"
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
@using budget_management_system_aspdotnetcore.Entities

<div class="container-fluid">

    @{
        var userRole = Model.userRole;
    }

    <!-- Budget Amendment History Card -->
    <div class="card mb-4 shadow-sm" style="border-radius: 10px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 10px;">
                <h3 class="page-title">Budget Amendments</h3>
                <form method="post" asp-page-handler="ExportToExcelBudgetAmendments" id="baExportForm">
                    <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                    <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                    <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                    <input type="hidden" name="BudgetAmendmentSearchTerm" value="@Model.BudgetAmendmentSearchTerm" />
                    <input type="hidden" name="ExportType" value="current" id="baExportTypeInput" />
                    <div class="btn-group">
                        <button type="submit" class="btn btn-outline-success" id="baExportBtn"
                                onclick="triggerExport('baExportForm', 'baExportBtn', 'baExportTypeInput', 'current')">
                            <i class="fas fa-file-excel me-1"></i> Export Current View
                        </button>
                        <button type="button" class="btn btn-outline-success dropdown-toggle dropdown-toggle-split"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="visually-hidden">Toggle Dropdown</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#"
                                   onclick="triggerExport('baExportForm', 'baExportBtn', 'baExportTypeInput', 'summary'); return false;">
                                    <i class="fas fa-layer-group me-2"></i>Export All (Summary)
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#"
                                   onclick="triggerExport('baExportForm', 'baExportBtn', 'baExportTypeInput', 'detail'); return false;">
                                    <i class="fas fa-table me-2"></i>Export All (Detail)
                                </a>
                            </li>
                        </ul>
                    </div>
                </form>
            </div>

            <div class="d-flex align-items-end justify-content-between flex-wrap gap-3">
                @{
                    var fyFilterModel = new FinancialYearFilterViewModel
                    {
                        FinancialYearOptions = Model.FinancialYearOptions,
                        SelectedFinancialYear = Model.SelectedFinancialYear,
                        CustomStartDate = Model.CustomStartDate,
                        CustomEndDate = Model.CustomEndDate,
                        HiddenFields = new Dictionary<string, string>
                        {
                            ["SelectedDepartmentID"] = Model.SelectedDepartmentID.ToString(),
                            ["SelectedStatusTab"] = Model.SelectedStatusTab ?? "",
                            ["SelectedBAMainStatusTab"] = Model.SelectedBAMainStatusTab ?? "",
                            ["SelectedBudgetAmendmentMainID"] = Model.SelectedBudgetAmendmentMainID?.ToString() ?? ""
                        }
                    };
                }
                <partial name="_FinancialYearFilter" model="fyFilterModel" />
            </div>



            <!-- Budget Amendments Section -->
            <div class="mb-4">
                @{
                    var tabBarModel = new BAMainTabBarViewModel
                    {
                        SelectedBAMainStatusTab = Model.SelectedBAMainStatusTab,
                        SelectedFinancialYear = Model.SelectedFinancialYear,
                        CustomStartDate = Model.CustomStartDate,
                        CustomEndDate = Model.CustomEndDate,
                        TabCounts = new Dictionary<string, int>
                        {
                            [""] = Model.BudgetAmendmentsMainAll.Count,
                            ["Pending"] = Model.BudgetAmendmentsMainAll.Count(bam =>
                                Model.BudgetAmendmentsAll.Any(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID && ba.Status == AmendmentStatus.Pending)),
                            ["Approved"] = Model.BudgetAmendmentsMainAll.Count(bam => {
                                var rel = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID).ToList();
                                return rel.Any() && rel.All(ba => ba.Status == AmendmentStatus.Approved);
                            }),
                            ["Rejected"] = Model.BudgetAmendmentsMainAll.Count(bam => {
                                var rel = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == bam.BudgetAmendmentMainID).ToList();
                                return rel.Any() && rel.All(ba => ba.Status == AmendmentStatus.Rejected);
                            })
                        }
                    };
                }
                <partial name="_BAMainTabBar" model="tabBarModel" />

            @if (!Model.BudgetAmendmentsMain.Any())
            {
                <div class="d-flex justify-content-center align-items-center">
                    <div class="card" style="background-color: #e9ecef; border: 1px solid #dee2e6; padding: 3rem; width: 100%;">
                        <div class="card-body text-center">
                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">No records found</p>
                            <small class="text-muted">Create a new amendment from the Modify Budget Amendments tab or adjust your filters</small>
                        </div>
                    </div>
                </div>
            }

            else
            {
                    <div class="mb-4">
                    <div class="accordion" id="budgetAmendmentsAccordion">

                        @{
                            var baIndex = 0;
                            var userDepartmentsBA = Model.DepartmentsUserIsResponsibleFor;
                        }
                        @foreach (var amendmentmain in Model.BudgetAmendmentsMain)
                        {
                            var amendmentIndex = baIndex;
                            baIndex++;
                            var isFirstLoadDefault = amendmentIndex == 0 && Model.SelectedDepartmentID == 0 && !Model.SelectedBudgetAmendmentMainID.HasValue;

                            
                                var baRelated = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID).ToList();
                                var baMainStatus = baRelated.Any(ba => ba.Status == AmendmentStatus.Pending) ? "Pending"
                                    : (baRelated.Any() && baRelated.All(ba => ba.Status == AmendmentStatus.Approved)) ? "Approved"
                                    : (baRelated.Any() && baRelated.All(ba => ba.Status == AmendmentStatus.Rejected)) ? "Rejected"
                                    : "None";
                            

                            <div class="accordion-item mb-3" data-ba-main-status="@baMainStatus">
                                <h2 class="accordion-header" id="headingBA@(amendmentIndex)">
                                    <button class="accordion-button @(isFirstLoadDefault ? "" : "collapsed") py-4" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#collapseBA@(amendmentIndex)"
                                            aria-expanded="@(isFirstLoadDefault ? "true" : "false")"
                                            aria-controls="collapseBA@(amendmentIndex)">
                                        <div class="d-flex justify-content-between w-100 align-items-center">
                                            <partial name="_BAMainHeader" model="new BAMainHeaderViewModel { Record = amendmentmain, Status = baMainStatus }" />

                                            @{
                                                var relatedAmendments = Model.BudgetAmendmentsAll.Where(ba => ba.BudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID).ToList();

                                                if (relatedAmendments.Any(ba => ba.Status == AmendmentStatus.Pending))
                                                {
                                                    <span class="badge text-primary">PENDING</span>
                                                }
                                                else if (relatedAmendments.Any() && relatedAmendments.All(ba => ba.Status == AmendmentStatus.Approved))
                                                {
                                                    <span class="badge text-success">APPROVED</span>
                                                }
                                                else if (relatedAmendments.Any() && relatedAmendments.All(ba => ba.Status == AmendmentStatus.Rejected))
                                                {
                                                    <span class="badge text-danger">REJECTED</span>
                                                }
                                            }
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapseBA@(amendmentIndex)" class="accordion-collapse collapse @(isFirstLoadDefault ? "show" : "")"
                                     aria-labelledby="headingBA@(amendmentIndex)"
                                     data-bs-parent="#budgetAmendmentsAccordion"
                                     data-ba-id="@amendmentmain.BudgetAmendmentMainID">
                                    <div class="accordion-body">
                                        <!-- Nested Accordion for Departments -->
                                        <div class="accordion" id="departmentsBA@(amendmentIndex)">

                                            @{ var deptIndex = 0; }
                                            @foreach (var dept in userDepartmentsBA)
                                            {
                                                var deptId = $"Dept{dept.DepartmentID}";
                                                var isDefaultExpanded = amendmentIndex == 0 && deptIndex == 0 && Model.SelectedDepartmentID == 0 && !Model.SelectedBudgetAmendmentMainID.HasValue;
                                                var isDeptSelected = Model.SelectedDepartmentID == dept.DepartmentID && Model.SelectedBudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID;
                                                deptIndex++;

                                                <div class="accordion-item mb-2">
                                                    <h2 class="accordion-header" id="heading@(deptId)BA@(amendmentIndex)">
                                                        <a href="@(isDeptSelected ? "javascript:void(0);" : $"?SelectedDepartmentID={dept.DepartmentID}&SelectedStatusTab={Model.SelectedStatusTab}&SelectedBAMainStatusTab={Model.SelectedBAMainStatusTab}&SelectedBudgetAmendmentMainID={amendmentmain.BudgetAmendmentMainID}&SelectedFinancialYear={Model.SelectedFinancialYear}&CustomStartDate={Model.CustomStartDate?.ToString("yyyy-MM-dd")}&CustomEndDate={Model.CustomEndDate?.ToString("yyyy-MM-dd")}")"
                                                           class="inner-acc-btn accordion-button @(isDeptSelected || isDefaultExpanded ? "" : "collapsed") py-3 text-decoration-none"
                                                           style="display: block;"
                                                           @Html.Raw(isDeptSelected || isDefaultExpanded ? $"data-bs-toggle=\"collapse\" data-bs-target=\"#collapse{deptId}BA{amendmentIndex}\"" : "")>
                                                            
                                                            <div class="inner-acc-left">
                                                                <span class="inner-dept-name">@dept.DepartmentName</span>
                                                                @{
                                                                    var relatedDeptAmendments = Model.BudgetAmendmentsAll
                                                                        .Where(ba => ba.DepartmentID == dept.DepartmentID).ToList();

                                                                    if (relatedDeptAmendments.Any(ba => ba.Status == AmendmentStatus.Pending))
                                                                    {
                                                                        <span class="inner-pipe">|</span>
                                                                        <span class="inner-status inner-status--pending">Pending</span>
                                                                    }
                                                                    else if (relatedDeptAmendments.Any() && relatedDeptAmendments.All(ba => ba.Status == AmendmentStatus.Approved))
                                                                    {
                                                                        <span class="inner-pipe">|</span>
                                                                        <span class="inner-status inner-status--approved">Approved</span>
                                                                    }
                                                                    else if (relatedDeptAmendments.Any() && relatedDeptAmendments.All(ba => ba.Status == AmendmentStatus.Rejected))
                                                                    {
                                                                        <span class="inner-pipe">|</span>
                                                                        <span class="inner-status inner-status--rejected">Rejected</span>
                                                                    }
                                                                }
                                                            </div>

                                                            <svg class="inner-chevron" width="16" height="16" viewBox="0 0 16 16"
                                                                 fill="none" stroke="currentColor" stroke-width="1.75">
                                                                <path d="M4 6l4 4 4-4"/>
                                                            </svg>
                                                           
                                                        </a>
                                                    </h2>
                                                    <div id="collapse@(deptId)BA@(amendmentIndex)" class="accordion-collapse collapse @(isDefaultExpanded ? "show" : "")"
                                                         aria-labelledby="heading@(deptId)BA@(amendmentIndex)"
                                                         data-bs-parent="#departmentsBA@(amendmentIndex)"
                                                         data-dept-id="@dept.DepartmentID">

                                                        <div class="accordion-body">

                                                            <!-- Search Bar -->
                                                            <div class="d-flex gap-2 mb-3">
                                                                <form method="get" class="flex-grow-1">
                                                                    <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                    <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                    <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                    <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                    <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                    <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                    <div class="input-group">
                                                                        <input type="text" name="BudgetAmendmentSearchTerm" class="form-control" placeholder="Search..." value="@Model.BudgetAmendmentSearchTerm" />
                                                                        <button type="submit" class="btn btn-outline-secondary">Search</button>
                                                                    </div>
                                                                </form>


                                                                @if (Model.SelectedStatusTab == AmendmentStatus.Pending.ToString() && !String.Equals(userRole, "5"))
                                                                {
                                                                    <form method="post" asp-page-handler="ApproveCategory" onsubmit="return validateNetChange(this)">
                                                                        <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                        <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                        <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                        <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                        <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                        <button type="submit" onclick="return confirm('Are you sure you want to approve all these entries?');" disabled=@(!Model.BudgetAmendments.Any()) class="btn btn-link">Approve All ✔️</button>
                                                                    </form>

                                                                    <form method="post" asp-page-handler="RejectCategory">
                                                                        <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                        <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                        <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                        <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                        <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                        <button type="submit" onclick="return confirm('Are you sure you want to reject all these entries?');" disabled=@(!Model.BudgetAmendments.Any()) class="btn btn-link">Reject All ❌</button>
                                                                    </form>

                                                                }

                                                                else if(Model.SelectedStatusTab == AmendmentStatus.Approved.ToString() && !String.Equals(userRole, "5"))
                                                                {
                                                                    <form method="post" asp-page-handler="RevertCategory">
                                                                        <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                        <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                        <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                        <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                        <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                        <button type="submit" onclick="return confirm('Are you sure you want to undo this decision?');" disabled=@(!Model.BudgetAmendments.Any()) class="btn btn-link text-nowrap">Revert Decision ↩️</button>
                                                                    </form>
                                                                }

                                                                @if (Model.SelectedStatusTab == AmendmentStatus.Rejected.ToString())
                                                                {
                                                                    <form method="post" asp-page-handler="RevertCategory">
                                                                        <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                        <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                        <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                        <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                        <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                        <button type="submit" onclick="return confirm('Are you sure you want to resubmit these entries for review?');" disabled=@(!Model.BudgetAmendments.Any()) class="btn btn-link text-nowrap">Resubmit for review 🗒️</button>
                                                                    </form>
                                                                }

                                                                else if (Model.SelectedStatusTab == AmendmentStatus.Draft.ToString())
                                                                {
                                                                    <form method="post" asp-page-handler="SubmitCategory">
                                                                        <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                        <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                        <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                        <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                        <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />

                                                                        <div class="text-end">
                                                                            <div class="d-flex align-items-end gap-2 flex-wrap justify-content-end">

                                                                                @if (Model.BudgetAmendmentMainEndDate < DateTime.Now)
                                                                                {
                                                                                    <button class="btn btn-link text-nowrap" onclick="return alert(`Error: The submission deadline for this budget amendment has passed.`);" disabled="@(!Model.BudgetAmendments.Any())">Submit Drafts for review 🗒️</button>
                                                                                }

                                                                                else 
                                                                                {
                                                                                    <form method="post" asp-page-handler="SubmitSelectedCategories" class="d-inline">
                                                                                        <input type="hidden" name="SelectedCategoryList" id="selectedCategoryList" />
                                                                                            <button type="submit" class="btn btn-link text-nowrap" onclick="return confirm(`Are you sure you want to submit all Drafts for review?`);" id="submitBtn" disabled="@(!Model.BudgetAmendments.Any())">Submit Drafts for review 🗒️</button>
                                                                                     </form>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    </form>
                                                                }

                                                                else 
                                                                {}

                                                                @if (Model.BudgetAmendmentMainEndDate < DateTime.Now)
                                                                {
                                                                    <button type="button" class="btn btn-primary flex-shrink-0" onclick="return alert(`Error: The submission deadline for this budget amendment has passed.`);" )>
                                                                        Create New +
                                                                    </button>
                                                                }

                                                                else
                                                                {
                                                                    <button type="button" class="btn btn-primary flex-shrink-0" data-bs-toggle="modal" data-bs-target="#addAmendmentModal"
                                                                            @(DateTime.Now < Model.BudgetAmendmentMainStartDate || DateTime.Now > Model.BudgetAmendmentMainEndDate ? "disabled" : "")>
                                                                        Create New +
                                                                    </button>
                                                                }
                                                            </div>

                                                            <!-- Status Tabs for this department -->                                                            <!-- Status Tabs for this department -->
                                                            <ul class="nav nav-tabs justify-content-center mb-3">
                                                                @{
                                                                    var statuses = Enum.GetValues<budget_management_system_aspdotnetcore.Entities.AmendmentStatus>();
                                                                }
                                                                @foreach (var status in statuses)
                                                                {
                                                                    var isActive = Model.SelectedStatusTab == status.ToString() ? "active" : "";
                                                                    var statusCount = Model.BudgetAmendmentsAll
                                                                        .Count(ba => ba.BudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID
                                                                                  && ba.DepartmentID == dept.DepartmentID
                                                                                  && ba.Status == status);
                                                                    <li class="nav-item">
                                                                        <a class="nav-link @isActive"
                                                                           href="?SelectedDepartmentID=@dept.DepartmentID&SelectedStatusTab=@status&SelectedBAMainStatusTab=@Model.SelectedBAMainStatusTab&SelectedBudgetAmendmentMainID=@amendmentmain.BudgetAmendmentMainID&SelectedFinancialYear=@Model.SelectedFinancialYear&CustomStartDate=@Model.CustomStartDate?.ToString("yyyy-MM-dd")&CustomEndDate=@Model.CustomEndDate?.ToString("yyyy-MM-dd")">@status.GetDisplayName()@if (statusCount > 0) { <span class="badge bg-danger">@statusCount</span> }</a>
                                                                    </li>
                                                                }
                                                                @{
                                                                    var isAllActive = string.IsNullOrEmpty(Model.SelectedStatusTab) ? "active" : "";
                                                                    var allCount = Model.BudgetAmendmentsAll
                                                                        .Count(ba => ba.BudgetAmendmentMainID == amendmentmain.BudgetAmendmentMainID
                                                                                  && ba.DepartmentID == dept.DepartmentID);
                                                                }
                                                                <li class="nav-item tab-all-separator">
                                                                    <a class="nav-link @isAllActive"
                                                                       href="?SelectedDepartmentID=@dept.DepartmentID&SelectedStatusTab=&SelectedBAMainStatusTab=@Model.SelectedBAMainStatusTab&SelectedBudgetAmendmentMainID=@amendmentmain.BudgetAmendmentMainID&SelectedFinancialYear=@Model.SelectedFinancialYear&CustomStartDate=@Model.CustomStartDate?.ToString("yyyy-MM-dd")&CustomEndDate=@Model.CustomEndDate?.ToString("yyyy-MM-dd")">All
                                                                        @if (allCount > 0) { <span class="badge badge-ghost">@allCount</span> }
                                                                    </a>
                                                                </li>
                                                            </ul>

                                                            <div class="table-responsive">
                                                                <table class="table table-bordered table-striped table-hover text-center">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>
                                                                                #
                                                                            </th>
                                                                            <th>
                                                                                Category Name
                                                                                <form method="get" class="d-inline">
                                                                                    <input type="hidden" name="handler" value="SortColumn" />
                                                                                    <input type="hidden" name="table" value="AmendmentHistory" />
                                                                                    <input type="hidden" name="column" value="CategoryName" />
                                                                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("CategoryName")" />
                                                                                    <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                                    <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                                    <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />
                                                                                    <input type="hidden" name="SelectedFinancialYear" value="@Model.SelectedFinancialYear" />
                                                                                    <input type="hidden" name="CustomStartDate" value="@Model.CustomStartDate?.ToString("yyyy-MM-dd")" />
                                                                                    <input type="hidden" name="CustomEndDate" value="@Model.CustomEndDate?.ToString("yyyy-MM-dd")" />
                                                                                    <button type="submit" class="btn btn-link p-0">
                                                                                        <i class="fas @Model.GetSortIcon("CategoryName")"></i>
                                                                                    </button>
                                                                                </form>
                                                                            </th>
                                                                            <th>
                                                                                Adjustment Detail
                                                                            </th>
                                                                            <th>
                                                                                SpeedType
                                                                            </th>
                                                                            <th>
                                                                                Fund Code
                                                                                <form method="get" class="d-inline">
                                                                                    <input type="hidden" name="handler" value="SortColumn" />
                                                                                    <input type="hidden" name="table" value="AmendmentHistory" />
                                                                                    <input type="hidden" name="column" value="FundCode" />
                                                                                    <input type="hidden" name="order" value="@Model.SortOrderForColumn("FundCode")" />
                                                                                    <input type="hidden" name="SelectedDepartmentID" value="@Model.SelectedDepartmentID" />
                                                                                    <input type="hidden" name="SelectedStatusTab" value="@Model.SelectedStatusTab" />
                                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                        <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                    <input type="hidden" name="SelectedBAMainStatusTab" value="@Model.SelectedBAMainStatusTab" />
                                                                                    <input type="hidden" name="SelectedBudgetAmendmentMainID" value="@Model.SelectedBudgetAmendmentMainID" />

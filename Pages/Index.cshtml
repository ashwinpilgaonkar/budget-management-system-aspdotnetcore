                                                                    PrevUrl = $"?amendmentPageNumber={Model.BudgetAmendmentCurrentPage - 1}&amendmentsPerPage={Model.BudgetAmendmentResultsPerPage}{amendmentFilters}",
                                                                    NextUrl = $"?amendmentPageNumber={Model.BudgetAmendmentCurrentPage + 1}&amendmentsPerPage={Model.BudgetAmendmentResultsPerPage}{amendmentFilters}",
                                                                    SizeChangeUrlTemplate = $"?amendmentPageNumber=1&amendmentsPerPage=__SIZE__{amendmentFilters}"
                                                                };
                                                                await Html.RenderPartialAsync("_Pagination", amendmentPagination);
                                                            }

                                                        </div>
                                                    </div>
                                                </div>
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        }


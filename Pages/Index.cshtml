                                                                                                    </form>
                                                                                                </div>
                                                                                            }
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                                index++;
                                                                            }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>

                                                            @{
                                                                var amendmentFilters = $"&SelectedDepartmentID={Model.SelectedDepartmentID}&SelectedStatusTab={Model.SelectedStatusTab}&SelectedBAMainStatusTab={Model.SelectedBAMainStatusTab}&SelectedBudgetAmendmentMainID={Model.SelectedBudgetAmendmentMainID}&SelectedFinancialYear={Model.SelectedFinancialYear}&CustomStartDate={Model.CustomStartDate?.ToString("yyyy-MM-dd")}&CustomEndDate={Model.CustomEndDate?.ToString("yyyy-MM-dd")}&BudgetAmendmentSearchTerm={Model.BudgetAmendmentSearchTerm}&SortColumn={Model.SortColumn}&SortOrder={Model.SortOrder}&ActiveSortTable={Model.ActiveSortTable}&SelectedCreatedBy={Model.SelectedCreatedBy}&CreatedFromDate={Model.CreatedFromDate?.ToString("yyyy-MM-dd")}&CreatedToDate={Model.CreatedToDate?.ToString("yyyy-MM-dd")}&SelectedEditedBy={Model.SelectedEditedBy}&EditedFromDate={Model.EditedFromDate?.ToString("yyyy-MM-dd")}&EditedToDate={Model.EditedToDate?.ToString("yyyy-MM-dd")}&SelectedUpdatedBy={Model.SelectedUpdatedBy}&UpdatedFromDate={Model.UpdatedFromDate?.ToString("yyyy-MM-dd")}&UpdatedToDate={Model.UpdatedToDate?.ToString("yyyy-MM-dd")}";
                                                                var amendmentPagination = new budget_management_system_aspdotnetcore.ViewModels.PaginationViewModel
